    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^4.3.1",
    "json-schema-to-typescript": "^15.0.4",
    "ts-node": "^10.9.0",
    "tsup": "^8.5.1",
