{
  "name": "tensorfleet-cli",
  "version": "0.0.1",
  "description": "TensorFleet CLI tool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tensorfleet": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm,cjs --dts --clean",
    "watch": "tsup src/cli.ts src/index.ts --format esm,cjs --dts --watch --clean",
    "start": "bun dist/cli.js",
    "run": "bun dist/cli.js"
  },
  "keywords": [
    "cli",
    "tensorfleet"
  ],
  "author": "TensorFleet",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "tensorfleet-tools": "workspace:*"
  }
}