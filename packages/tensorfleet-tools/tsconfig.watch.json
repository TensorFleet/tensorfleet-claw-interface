{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*",
    "packages/*/src/**/*",
    "packages/@types/*/src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}