{
  "name": "tensorfleet-tools",
  "version": "1.0.0",
  "description": "Empty TypeScript Node.js project",
  "main": "dist/index.js",
  "workspaces": [
    "packages/*",
    "packages/@types/*"
  ],
  "scripts": {
    "dev": "vite",
    "watch": "vite build --watch",
    "build": "bun run generate:schema-types && vite build",
    "preview": "vite preview",
    "generate:schema-types": "node scripts/generate-schema-types.cjs",
    "start": "node dist/index.js",
    "build:workspace": "bun run build --filter=packages/*",
    "build:packages": "bun run build:workspace",
    "build:all": "bun run build && bun run build:packages"
  },
  "keywords": [
    "typescript",
    "nodejs"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.28.4",
