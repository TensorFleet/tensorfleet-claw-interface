{
  "name": "tensorfleet-tools",
  "version": "1.0.0",
  "description": "TensorFleet shared tools library",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "watch": "sh -c 'cd ../..; bun run --filter tensorfleet-util build || true; bun run --filter tensorfleet-ros build || true; cd packages/tensorfleet-tools; bun run generate:schema-types || true; tsup --watch || true; exit 0'",
    "build": "sh -c 'cd ../..; bun run --filter tensorfleet-util build || true; bun run --filter tensorfleet-ros build || true; cd packages/tensorfleet-tools; bun run generate:schema-types || true; tsup || true; exit 0'",
    "generate:schema-types": "node scripts/generate-schema-types.cjs",
    "codegen": "bun run generate:schema-types",
    "start": "bun dist/index.js"
  },
  "keywords": [
    "typescript",
    "nodejs"
  ],
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fluentui/react-icons": "^2.0.315",
    "@foxglove/rosmsg-msgs-common": "^3.2.3",
    "@foxglove/rosmsg2-serialization": "^3.0.3",
    "@foxglove/schemas": "^1.8.0",
    "@foxglove/ws-protocol": "^0.8.0",
    "@lichtblick/den": "workspace:*",
    "@lichtblick/hooks": "workspace:*",
    "@lichtblick/log": "workspace:*",
    "@lichtblick/mcap-support": "workspace:*",
    "@lichtblick/message-definition": "^1.0.0",
    "@lichtblick/omgidl-parser": "^1.0.0",
    "@lichtblick/omgidl-serialization": "^1.0.0",
    "@lichtblick/ros2idl-parser": "^1.0.0",
    "@lichtblick/rosmsg": "^1.0.0",
    "@lichtblick/rosmsg-msgs-common": "^1.0.1",
    "@lichtblick/rosmsg-serialization": "^1.0.0",
    "@lichtblick/rosmsg2-serialization": "^1.0.0",
    "@lichtblick/rostime": "^1.0.0",
    "@lichtblick/suite": "workspace:*",
    "@lichtblick/suite-base": "workspace:*",
    "@lichtblick/tsconfig": "^1.0.2",
    "@lichtblick/velodyne-cloud": "^1.0.0",
    "@lichtblick/wasm-bz2": "^1.0.0",
    "@lichtblick/wasm-lz4": "^1.0.0",
    "@lichtblick/wasm-zstd": "^1.0.0",
    "@mcap/core": "^2.1.7",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.5",
    "@protobufjs/base64": "^1.1.2",
    "@sinclair/typebox": "^0.33.22",
    "bufferutil": "^4.1.0",
    "canvas": "^3.2.1",
    "cbor-x": "^1.6.0",
    "cbor2": "^2.0.1",
    "dotenv": "^16.5.0",
    "flatbuffers": "^25.9.23",
    "flatbuffers_reflection": "^1.2.0",
    "i18next": "^25.6.3",
    "jsdom": "^29.0.0",
    "lodash-es": "^4.17.21",
    "ol": "^10.7.0",
    "pino": "^10.3.1",
    "protobufjs": "^7.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hover-observer": "^1.0.17",
    "react-i18next": "^16.3.5",
    "react-json-tree": "^0.20.0",
    "react-use": "^17.6.0",
    "tensorfleet-ros": "workspace:*",
    "tensorfleet-util": "workspace:*",
    "three": "^0.181.2",
    "three-nebula": "^10.0.3",
    "tinycolor2": "^1.6.0",
    "tss-react": "^4.9.19",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.9.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.181.0",
    "@types/ws": "^8.18.1",
    "json-schema-to-typescript": "^15.0.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}