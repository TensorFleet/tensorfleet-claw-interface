{
  "name": "tensorfleet-claw-interface",
  "version": "1.0.0",
  "description": "Tensorfleet tools and openclaw packages",
  "main": "packages/tensorfleet-openclaw-plugin/dist/index.js",
  "private": true,
  "packageManager": "bun@1.1.0",
  "workspaces": [
    "packages/*",
    "packages/tensorfleet-tools/packages/*",
    "packages/tensorfleet-tools/packages/@types/*"
  ],
  "scripts": {
    "build": "turbo run tensorfleet-tools#build tensorfleet-cli#build tensorfleet-openclaw-plugin#build --concurrency=1 --no-cache",
    "watch": "turbo watch tensorfleet-util#build tensorfleet-tools#build tensorfleet-cli#build tensorfleet-openclaw-plugin#build --concurrency=1",
    "cli": "cd packages/tensorfleet-cli && bun dist/cli.mjs",
    "codegen": "bun run --filter tensorfleet-tools codegen"
  },
  "keywords": [
    "typescript",
    "nodejs"
  ],
  "author": "",
  "dependencies": {
    "@types/bun": "^1.3.11"
  },
  "openclaw": {
    "extensions": [
      "./packages/tensorfleet-openclaw-plugin/dist/index.js"
    ]
  },
  "devDependencies": {
    "@foxglove/wasm-bz2": "^0.1.1",
    "@foxglove/wasm-lz4": "^1.0.2",
    "@foxglove/wasm-zstd": "^1.0.1",
    "@rollup/plugin-url": "^8.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^4.3.1",
    "json-schema-to-typescript": "^15.0.4",
    "ts-node": "^10.9.0",
    "tsup": "^8.5.1",
    "turbo": "^2.8.20",
    "typescript": "^5.8.0",
    "vite": "^5.4.2"
  }
}
