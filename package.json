{
  "name": "tensorfleet-claw-interface",
  "version": "1.0.0",
  "description": "Empty TypeScript Node.js project",
  "main": "dist/index.js",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/tensorfleet-tools/packages/*",
    "packages/tensorfleet-tools/packages/@types/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=./packages/tensorfleet-openclaw-plugin --filter=./packages/tensorfleet-cli",
    "watch": "turbo watch build --filter=./packages/tensorfleet-openclaw-plugin --filter=./packages/tensorfleet-cli",
    "build:tools": "cd packages/tensorfleet-tools && bun run build",
    "build:plugin": "cd packages/tensorfleet-openclaw-plugin && bun run build",
    "build:cli": "cd packages/tensorfleet-cli && bun run build",
    "cli": "cd packages/tensorfleet-cli && bun dist/cli.js"
  },
  "keywords": [
    "typescript",
    "nodejs"
  ],
  "author": "",
  "dependencies": {},
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@foxglove/wasm-bz2": "^0.1.1",
    "@foxglove/wasm-lz4": "^1.0.2",
    "@foxglove/wasm-zstd": "^1.0.1",
    "@rollup/plugin-url": "^8.0.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^4.3.1",
    "json-schema-to-typescript": "^15.0.4",
    "ts-node": "^10.9.0",
    "tsup": "^8.5.1",
    "turbo": "^2.1.0",
    "typescript": "^5.8.0",
    "vite": "^5.4.2"
  }
}