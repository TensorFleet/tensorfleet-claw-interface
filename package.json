{
  "name": "tensorfleet-claw-interface",
  "version": "1.0.0",
  "description": "Empty TypeScript Node.js project",
  "main": "dist/index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate:schema-types": "node scripts/generate-schema-types.cjs",
    "build": "npm run generate:schema-types && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "build:packages": "npm run build --workspaces",
    "build:all": "npm run build && npm run build:packages"
  },
  "keywords": [
    "typescript",
    "nodejs"
  ],
  "author": "",
  "dependencies": {
    "@sinclair/typebox": "^0.33.22"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}