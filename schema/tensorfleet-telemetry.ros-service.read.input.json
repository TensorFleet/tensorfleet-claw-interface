{
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "service_id": { 
            "type": "string",
            "description": "Global ROS path of the service. Use `\"--list\"` for `service_id` to get a list of available services and their schema."
        },
        "arguments": {
            "type": "object",
            "description": "Arguments to pass. Type/Schema depends on the ROS service"
        },
        "return_type": {
            "type": "string",
            "default": "JSON",
            "description": "The return type for the response, defaults to JSON"
        }
    },
    "top_filter": {
        "type": "object",
        "description": "Top-level filter to apply to the query",
        "properties": {
            "field": {
                "type": "string",
                "description": "Field to filter on"
            },
            "operator": {
                "type": "string",
                "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "nin", "like", "regex"],
                "description": "Operator to use for filtering"
            },
            "value": {
                "type": "string",
                "description": "Value to filter by"
            }
        },
        "required": ["field", "operator", "value"],
        "additionalProperties": false
    },
    "required": ["service_id", "arguments"]
}
